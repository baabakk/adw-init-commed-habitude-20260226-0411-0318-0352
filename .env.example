# Server Configuration
PORT=3000
NODE_ENV=development
DATABASE_PATH=./data/habits.db
TIMEZONE=UTC

# Twilio SMS Configuration
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Telegram Configuration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# WhatsApp Business API Configuration
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Rate Limiting (messages per time window)
SMS_RATE_LIMIT_PER_MINUTE=10
SMS_RATE_LIMIT_PER_HOUR=100
TELEGRAM_RATE_LIMIT_PER_MINUTE=30
TELEGRAM_RATE_LIMIT_PER_HOUR=1000
WHATSAPP_RATE_LIMIT_PER_MINUTE=20
WHATSAPP_RATE_LIMIT_PER_HOUR=500

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY_MS=1000
RETRY_MAX_DELAY_MS=10000

# Cache Configuration
CHART_CACHE_TTL_SECONDS=300
